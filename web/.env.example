# --- Database (Neon) --- get BOTH from Neon Console → Connect
DATABASE_URL="postgresql://USER:PASSWORD@EP-xxxx-pooler.REGION.aws.neon.tech/DB?sslmode=require"  # pooled — app
DIRECT_URL="postgresql://USER:PASSWORD@EP-xxxx.REGION.aws.neon.tech/DB?sslmode=require"           # direct — migrations

# --- Auth (Clerk) --- chunk 0.2; get keys from Clerk Dashboard → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Clerk route config
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# --- Platform super-admins (chunk 0.2) --- comma-separated Clerk user IDs (include yours)
PLATFORM_ADMIN_USER_IDS=

# --- Clerk webhook (chunk 0.3) --- Clerk Dashboard → Webhooks → signing secret (whsec_...)
CLERK_WEBHOOK_SECRET=

# --- Credential vault (chunk 1.1) --- 32-byte base64 key, generate later
ENCRYPTION_KEY=

# --- Platform AI key for label scan (chunk 1.2) ---
ANTHROPIC_API_KEY=
